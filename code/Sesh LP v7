// ═════════════════════════════════════════════════════════════════════════════
// ACTIVE SESSION DETECTION
// Which session range drives signals on the current bar
// London : 3:00 AM – 9:00 AM
// NY     : 9:00 AM – 7:00 PM
// Asian  : 7:00 PM – 3:00 AM
// ═════════════════════════════════════════════════════════════════════════════
bool active_ny  = ny_in
bool active_ld  = ld_in
bool active_as  = as_in

// Pull the active session's levels into generic aliases for signal logic
float act_hi_5m  = active_ny ? ny_hi_5m  : active_ld ? ld_hi_5m  : active_as ? as_hi_5m  : na
float act_lo_5m  = active_ny ? ny_lo_5m  : active_ld ? ld_lo_5m  : active_as ? as_lo_5m  : na
float act_mean   = active_ny ? ny_mean   : active_ld ? ld_mean   : active_as ? as_mean   : na
float act_median = active_ny ? ny_median : active_ld ? ld_median : active_as ? as_median : na
bool  act_in     = active_ny or active_ld or active_as

string act_name  = active_ny ? "NY" : active_ld ? "London" : active_as ? "Asian" : "—"
color  act_col   = active_ny ? col_ny : active_ld ? col_ld : active_as ? col_as : color.gray

// ═════════════════════════════════════════════════════════════════════════════
// PLOT RANGE LINES
// 5m H/L + Mean + Median only = 12 plots total (well under the 64 limit)
// Extended snap levels (10m/15m/30m/60m) are tracked but shown via labels only
// ═════════════════════════════════════════════════════════════════════════════

// NY — 4 plots
plot(show_ranges ? ny_hi_5m  : na, "NY 5m H",   color = col_ny,                linewidth = 2, style = plot.style_stepline)
plot(show_ranges ? ny_lo_5m  : na, "NY 5m L",   color = col_ny,                linewidth = 2, style = plot.style_stepline)
plot(show_mean   ? ny_mean   : na, "NY Mean",   color = color.new(col_ny, 30), linewidth = 1, style = plot.style_stepline)
plot(show_median ? ny_median : na, "NY Median", color = color.new(col_ny, 55), linewidth = 1, style = plot.style_stepline)

// London — 4 plots
plot(show_ranges ? ld_hi_5m  : na, "LD 5m H",   color = col_ld,                linewidth = 2, style = plot.style_stepline)
plot(show_ranges ? ld_lo_5m  : na, "LD 5m L",   color = col_ld,                linewidth = 2, style = plot.style_stepline)
