plot(show_ranges ? as_lo_5m  : na, "AS 5m L",   color = col_as,                linewidth = 2, style = plot.style_stepline)
plot(show_mean   ? as_mean   : na, "AS Mean",   color = color.new(col_as, 30), linewidth = 1, style = plot.style_stepline)
plot(show_median ? as_median : na, "AS Median", color = color.new(col_as, 55), linewidth = 1, style = plot.style_stepline)


bgcolor(ny_snap_open or ld_snap_open or as_snap_open ? color.new(color.white, 80) : na, title = "Session Open Flash")

// ═════════════════════════════════════════════════════════════════════════════
// RANGE LABELS  (only on snap bars, active session only)
// ═════════════════════════════════════════════════════════════════════════════
if show_ranges and active_ny and ny_snap_5m and not na(ny_hi_5m)
    label.new(bar_index, ny_hi_5m, "NY 5m H", style = label.style_label_left, color = col_ny, textcolor = color.black, size = size.tiny)
    label.new(bar_index, ny_lo_5m, "NY 5m L", style = label.style_label_left, color = col_ny, textcolor = color.black, size = size.tiny)

if show_ranges and active_ld and ld_snap_5m and not na(ld_hi_5m)
    label.new(bar_index, ld_hi_5m, "LD 5m H", style = label.style_label_left, color = col_ld, textcolor = color.black, size = size.tiny)
    label.new(bar_index, ld_lo_5m, "LD 5m L", style = label.style_label_left, color = col_ld, textcolor = color.black, size = size.tiny)

if show_ranges and active_as and as_snap_5m and not na(as_hi_5m)
    label.new(bar_index, as_hi_5m, "AS 5m H", style = label.style_label_left, color = col_as, textcolor = color.black, size = size.tiny)
    label.new(bar_index, as_lo_5m, "AS 5m L", style = label.style_label_left, color = col_as, textcolor = color.black, size = size.tiny)

// ═════════════════════════════════════════════════════════════════════════════
// 5m ZONE BOX  (active session only)
// ═════════════════════════════════════════════════════════════════════════════
var box zone_box = na

if ny_snap_open or ld_snap_open or as_snap_open
    if not na(zone_box)
        box.delete(zone_box)
        zone_box := na

bool snap_5m_any = (active_ny and ny_snap_5m) or (active_ld and ld_snap_5m) or (active_as and as_snap_5m)

if show_5m_zone and snap_5m_any and not na(act_hi_5m)
    zone_box := box.new(
         left         = bar_index,
         top          = act_hi_5m,
         right        = bar_index + 1,
         bottom       = act_lo_5m,
         border_color = color.new(act_col, 60),
         bgcolor      = col_5m_neut,
         border_width = 1,
         xloc         = xloc.bar_index)

if show_5m_zone and not na(zone_box) and act_in and not na(act_hi_5m)
    box.set_right(zone_box, bar_index + 1)
    box.set_border_color(zone_box, color.new(act_col, 60))
    if close > act_hi_5m
        box.set_bgcolor(zone_box, col_5m_bull)
    else if close < act_lo_5m
        box.set_bgcolor(zone_box, col_5m_bear)
    else
        box.set_bgcolor(zone_box, col_5m_neut)

// ═════════════════════════════════════════════════════════════════════════════
// RSI DIVERGENCE ENGINE  (shared — one divergence engine across all sessions)
// ═════════════════════════════════════════════════════════════════════════════
rsi_val = ta.rsi(rsi_src, rsi_length)

pivot_lo_price = ta.pivotlow (low,     div_lookback, div_lookback)
pivot_hi_price = ta.pivothigh(high,    div_lookback, div_lookback)
pivot_lo_rsi   = ta.pivotlow (rsi_val, div_lookback, div_lookback)
pivot_hi_rsi   = ta.pivothigh(rsi_val, div_lookback, div_lookback)

var float prev_lo_price = na, var float prev_lo_rsi = na
var float last_lo_price = na, var float last_lo_rsi = na
var float prev_hi_price = na, var float prev_hi_rsi = na
var float last_hi_price = na, var float last_hi_rsi = na

if not na(pivot_lo_price)
    prev_lo_price := last_lo_price
    prev_lo_rsi   := last_lo_rsi
    last_lo_price := pivot_lo_price
    last_lo_rsi   := pivot_lo_rsi

if not na(pivot_hi_price)
    prev_hi_price := last_hi_price
    prev_hi_rsi   := last_hi_rsi
    last_hi_price := pivot_hi_price
    last_hi_rsi   := pivot_hi_rsi

bull_div_now = not na(prev_lo_price) and not na(last_lo_price) and
               last_lo_price < prev_lo_price and last_lo_rsi > prev_lo_rsi

bear_div_now = not na(prev_hi_price) and not na(last_hi_price) and
               last_hi_price > prev_hi_price and last_hi_rsi < prev_hi_rsi

var int bull_div_age = 999
var int bear_div_age = 999

bull_div_age := bull_div_now ? 0 : bull_div_age + 1
bear_div_age := bear_div_now ? 0 : bear_div_age + 1

recent_bull_div = bull_div_age <= div_memory
recent_bear_div = bear_div_age <= div_memory

// ═════════════════════════════════════════════════════════════════════════════
// RETEST STATE MACHINE  (runs on active session's 5m range)
// ═════════════════════════════════════════════════════════════════════════════
var int bull_state = 0
var int bear_state = 0

if ny_snap_open or ld_snap_open or as_snap_open
    bull_state := 0
    bear_state := 0

tol_v = retest_tol * syminfo.mintick

if not na(act_hi_5m) and not na(act_lo_5m) and act_in
    if bull_state == 0
        if close > act_hi_5m
            bull_state := 1
    else if bull_state == 1
        if close < act_lo_5m
            bull_state := 0
        else if low <= act_hi_5m + tol_v
            bull_state := 2
    else if bull_state == 2
        if close > act_hi_5m
            bull_state := 1
        else if close < act_lo_5m
            bull_state := 0

    if bear_state == 0
        if close < act_lo_5m
            bear_state := 1
    else if bear_state == 1
        if close > act_hi_5m
            bear_state := 0
        else if high >= act_lo_5m - tol_v
            bear_state := 2
    else if bear_state == 2
        if close < act_lo_5m
            bear_state := 1
        else if close > act_hi_5m
            bear_state := 0

retest_long_raw  = bull_state == 2 and not na(act_hi_5m) and close > act_hi_5m and act_in
retest_short_raw = bear_state == 2 and not na(act_lo_5m) and close < act_lo_5m and act_in

long_signal  = retest_long_raw  and (not require_div or recent_bull_div)
short_signal = retest_short_raw and (not require_div or recent_bear_div)

// ═════════════════════════════════════════════════════════════════════════════
// MEAN REJECTION ENGINE  (active session's mean)
// ═════════════════════════════════════════════════════════════════════════════
mean_tol_v = mean_rej_tol * syminfo.mintick

inside_range = not na(act_mean) and not na(act_hi_5m) and not na(act_lo_5m) and
               close <= act_hi_5m and close >= act_lo_5m and act_in

mean_touched_low  = false
mean_touched_high = false

if not na(act_mean)
    for i = 1 to mean_rej_bars
        if low[i]  <= act_mean + mean_tol_v and low[i]  >= act_mean - mean_tol_v
            mean_touched_low  := true
        if high[i] >= act_mean - mean_tol_v and high[i] <= act_mean + mean_tol_v
            mean_touched_high := true

mean_bull_rej_raw = inside_range and mean_touched_low  and close > act_mean and close > open
mean_bear_rej_raw = inside_range and mean_touched_high and close < act_mean and close < open

var int mean_rej_cooldown = 0
mean_rej_cooldown := mean_rej_cooldown > 0 ? mean_rej_cooldown - 1 : 0

mean_bull_rej = show_mean_rej and mean_bull_rej_raw and mean_rej_cooldown == 0
mean_bear_rej = show_mean_rej and mean_bear_rej_raw and mean_rej_cooldown == 0

if mean_bull_rej or mean_bear_rej
    mean_rej_cooldown := 5

