//@version=6
indicator("Sessions LP v7 — Auto 3-Session by 1vbo",
     shorttitle       = "Sesh LP v7",
     overlay          = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     max_boxes_count  = 500)

// ═════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═════════════════════════════════════════════════════════════════════════════
grp_sig = "── Signals ──────────────────────────────────"
rsi_length      = input.int   (14,   "RSI Length",                 minval = 2,  group = grp_sig)
rsi_src         = input.source(close,"RSI Source",                              group = grp_sig)
div_lookback    = input.int   (5,    "Divergence Lookback (bars)", minval = 2, maxval = 20, group = grp_sig)
require_div     = input.bool  (true, "Require RSI Divergence",                  group = grp_sig)
div_memory      = input.int   (20,   "Divergence Memory (bars)",  minval = 1, maxval = 50, group = grp_sig)
retest_tol      = input.float (1.0,  "Retest Tolerance (ticks)",  minval = 0., maxval = 10., step = 0.5, group = grp_sig)
show_labels     = input.bool  (true, "Show Long/Short Labels",                  group = grp_sig)
show_ranges     = input.bool  (true, "Show Range Lines",                        group = grp_sig)
show_state_dots = input.bool  (false,"Show State Indicator Dots",               group = grp_sig)

grp_mean = "── 5m Range Mean & Median ──────────────────"
show_mean     = input.bool  (true,  "Show Mean Line",              group = grp_mean)
show_median   = input.bool  (true,  "Show Median Line",            group = grp_mean)
show_mean_rej = input.bool  (true,  "Show Mean Rejection Signal",  group = grp_mean)
mean_rej_tol  = input.float (2.0,   "Rejection Tolerance (ticks)", group = grp_mean, minval = 0.5, maxval = 20., step = 0.5)
mean_rej_bars = input.int   (3,     "Rejection Confirm Bars",      group = grp_mean, minval = 1, maxval = 10)

grp_sess = "── Session Colours ──────────────────────────"
col_ny     = input.color(color.new(#00BFFF, 0),  "NY Colour",     group = grp_sess)
col_ld     = input.color(color.new(#FFD700, 0),  "London Colour", group = grp_sess)
col_as     = input.color(color.new(#FF69B4, 0),  "Asian Colour",  group = grp_sess)

grp_zone = "── 5m Zone Highlight ───────────────────────"
show_5m_zone = input.bool (true,  "Show 5m Zone Highlight",                   group = grp_zone)
col_5m_bull  = input.color(color.new(color.green, 75), "Bull (above hi_5m)", group = grp_zone)
col_5m_bear  = input.color(color.new(color.red,   75), "Bear (below lo_5m)", group = grp_zone)
col_5m_neut  = input.color(color.new(color.gray,  88), "Neutral (inside)",   group = grp_zone)

// ═════════════════════════════════════════════════════════════════════════════
// SESSION SNAP HELPERS
// ═════════════════════════════════════════════════════════════════════════════
f_snap(string sess) =>
    not na(time("1", sess)) and na(time("1", sess)[1])

// ── NY snaps (9:00 AM EST, weekdays) ─────────────────────────────────────────
bool ny_snap_open = f_snap("0900-0901:23456")
bool ny_snap_5m   = f_snap("0905-0906:23456")
bool ny_snap_10m  = f_snap("0910-0911:23456")
bool ny_snap_15m  = f_snap("0915-0916:23456")
bool ny_snap_30m  = f_snap("0930-0931:23456")
bool ny_snap_60m  = f_snap("1000-1001:23456")
bool ny_snap_4h   = f_snap("1300-1301:23456")
bool ny_snap_8h   = f_snap("1700-1701:23456")
bool ny_in        = not na(time("1", "0900-1900:23456"))
bool ny_med_win   = not na(time("1", "0900-0905:23456"))

// ── London snaps (3:00 AM EST, weekdays) ─────────────────────────────────────
