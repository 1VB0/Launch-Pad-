        int sz = array.size(ny_med_buf), int mid = int(sz / 2)
        ny_median := sz % 2 == 0 and sz >= 2 ? (array.get(ny_med_buf, mid-1) + array.get(ny_med_buf, mid)) / 2.0 : array.get(ny_med_buf, mid)
if ny_snap_10m
    ny_hi_10m := ny_roll_hi, ny_lo_10m := ny_roll_lo
if ny_snap_15m
    ny_hi_15m := ny_roll_hi, ny_lo_15m := ny_roll_lo
if ny_snap_30m
    ny_hi_30m := ny_roll_hi, ny_lo_30m := ny_roll_lo
if ny_snap_60m
    ny_hi_60m := ny_roll_hi, ny_lo_60m := ny_roll_lo
