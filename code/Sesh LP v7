var table leg = table.new(
     position.top_right, 3, 12,
     bgcolor      = color.new(color.black, 70),
     border_color = color.new(color.white, 55),
     border_width = 1,
     frame_color  = color.new(color.white, 35),
     frame_width  = 1)

if barstate.islast
    color hb  = color.new(color.gray, 45)
    color sbg = color.new(color.black, 55)

    table.cell(leg, 0, 0, "Active Session", text_color = color.white,  text_size = size.small, bgcolor = hb)
    table.cell(leg, 1, 0, act_name,         text_color = act_col,      text_size = size.small, bgcolor = hb)
    table.cell(leg, 2, 0, "",               bgcolor = act_col,          text_size = size.small)

    table.cell(leg, 0, 1, "NY 5m H/L",  text_color = col_ny, text_size = size.tiny, bgcolor = sbg)
    string ny_hl = not na(ny_hi_5m) ? str.tostring(ny_hi_5m, format.mintick) + " / " + str.tostring(ny_lo_5m, format.mintick) : "—"
    table.cell(leg, 1, 1, ny_hl, text_color = col_ny, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 1, "", bgcolor = color.new(col_ny, 50), text_size = size.tiny)
 
    table.cell(leg, 0, 2, "NY Mean",  text_color = col_ny, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 2, not na(ny_mean) ? str.tostring(ny_mean, format.mintick) : "—", text_color = col_ny, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 2, "", bgcolor = color.new(col_ny, 60), text_size = size.tiny)

    table.cell(leg, 0, 3, "LD 5m H/L",  text_color = col_ld, text_size = size.tiny, bgcolor = sbg)
    string ld_hl = not na(ld_hi_5m) ? str.tostring(ld_hi_5m, format.mintick) + " / " + str.tostring(ld_lo_5m, format.mintick) : "—"
    table.cell(leg, 1, 3, ld_hl, text_color = col_ld, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 3, "", bgcolor = color.new(col_ld, 50), text_size = size.tiny)

    table.cell(leg, 0, 4, "LD Mean",  text_color = col_ld, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 4, not na(ld_mean) ? str.tostring(ld_mean, format.mintick) : "—", text_color = col_ld, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 4, "", bgcolor = color.new(col_ld, 60), text_size = size.tiny)

    table.cell(leg, 0, 5, "AS 5m H/L",  text_color = col_as, text_size = size.tiny, bgcolor = sbg)
    string as_hl = not na(as_hi_5m) ? str.tostring(as_hi_5m, format.mintick) + " / " + str.tostring(as_lo_5m, format.mintick) : "—"
    table.cell(leg, 1, 5, as_hl, text_color = col_as, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 5, "", bgcolor = color.new(col_as, 50), text_size = size.tiny)

    table.cell(leg, 0, 6, "AS Mean",  text_color = col_as, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 6, not na(as_mean) ? str.tostring(as_mean, format.mintick) : "—", text_color = col_as, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 6, "", bgcolor = color.new(col_as, 60), text_size = size.tiny)

    string bull_st_txt = bull_state == 0 ? "idle" : bull_state == 1 ? "① broke ▲" : "② retest ▲"
    string bear_st_txt = bear_state == 0 ? "idle" : bear_state == 1 ? "① broke ▼" : "② retest ▼"
    color  bull_st_col = bull_state == 0 ? color.gray : bull_state == 1 ? color.new(color.lime, 40) : color.lime
    color  bear_st_col = bear_state == 0 ? color.gray : bear_state == 1 ? color.new(color.red,  40) : color.red

    table.cell(leg, 0, 7, "Bull State", text_color = color.silver, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 7, bull_st_txt,  text_color = bull_st_col,  text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 7, "",           bgcolor = bull_st_col,      text_size = size.tiny)

    table.cell(leg, 0, 8, "Bear State", text_color = color.silver, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 8, bear_st_txt,  text_color = bear_st_col,  text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 8, "",           bgcolor = bear_st_col,      text_size = size.tiny)

    table.cell(leg, 0, 9, "Bull Div",       text_color = color.silver,  text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 9, recent_bull_div ? "✔ recent" : "—", text_color = recent_bull_div ? color.lime : color.gray, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 9, "", bgcolor = recent_bull_div ? color.new(color.lime, 50) : color.new(color.gray, 70), text_size = size.tiny)

    table.cell(leg, 0, 10, "Bear Div",      text_color = color.silver,  text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 10, recent_bear_div ? "✔ recent" : "—", text_color = recent_bear_div ? color.red : color.gray, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 10, "", bgcolor = recent_bear_div ? color.new(color.red, 50) : color.new(color.gray, 70), text_size = size.tiny)

    string mean_sig = mean_bull_rej ? "M↑ Bounce" : mean_bear_rej ? "M↓ Reject" : "—"
    color  mean_col = mean_bull_rej ? color.lime   : mean_bear_rej ? color.red   : color.gray
    table.cell(leg, 0, 11, "Mean Sig",  text_color = color.silver, text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 1, 11, mean_sig,    text_color = mean_col,     text_size = size.tiny, bgcolor = sbg)
    table.cell(leg, 2, 11, "",          bgcolor = color.new(mean_col, 55), text_size = size.tiny)
