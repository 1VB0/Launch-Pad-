// ═════════════════════════════════════════════════════════════════════════════
// ROLLING HIGH / LOW  — one per session
// ═════════════════════════════════════════════════════════════════════════════
var float ny_roll_hi = na,  var float ny_roll_lo = na
var float ld_roll_hi = na,  var float ld_roll_lo = na
var float as_roll_hi = na,  var float as_roll_lo = na

// NY
if ny_snap_open
    ny_roll_hi := high
    ny_roll_lo := low
else if ny_in
    ny_roll_hi := math.max(ny_roll_hi, high)
    ny_roll_lo := math.min(ny_roll_lo, low)

// London
if ld_snap_open
    ld_roll_hi := high
    ld_roll_lo := low
else if ld_in
    ld_roll_hi := math.max(ld_roll_hi, high)
    ld_roll_lo := math.min(ld_roll_lo, low)

// Asian
if as_snap_open
    as_roll_hi := high
    as_roll_lo := low
else if as_in
    as_roll_hi := math.max(as_roll_hi, high)
    as_roll_lo := math.min(as_roll_lo, low)

