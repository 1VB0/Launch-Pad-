bool ld_snap_4h   = f_snap("0700-0701:23456")
bool ld_snap_8h   = f_snap("1100-1101:23456")
bool ld_in        = not na(time("1", "0300-0900:23456"))
bool ld_med_win   = not na(time("1", "0300-0305:23456"))

// ── Asian snaps (7:00 PM EST, all days) ──────────────────────────────────────
bool as_snap_open = f_snap("1900-1901:1234567")
bool as_snap_5m   = f_snap("1905-1906:1234567")
bool as_snap_10m  = f_snap("1910-1911:1234567")
bool as_snap_15m  = f_snap("1915-1916:1234567")
bool as_snap_30m  = f_snap("1930-1931:1234567")
bool as_snap_60m  = f_snap("2000-2001:1234567")
