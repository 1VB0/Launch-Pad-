float fpDelta     = array.sum(rawUp) + array.sum(rawDn)
float atr14        = ta.atr(14)
float fpSessRange = not na(svpSessH) and not na(svpSessL) ? math.max(svpSessH - svpSessL, syminfo.mintick) : atr14
